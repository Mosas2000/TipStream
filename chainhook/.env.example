# Chainhook Service Configuration

# Server
PORT=3100

# Authentication - Set to a strong random value for production
CHAINHOOK_AUTH_TOKEN=

# Storage backend
CHAINHOOK_STORAGE=postgres
DATABASE_URL=
CHAINHOOK_RETENTION_DAYS=30

# PostgreSQL Pool Configuration
DB_POOL_MAX=20
DB_POOL_IDLE_TIMEOUT_MS=30000
DB_POOL_CONNECTION_TIMEOUT_MS=5000
DB_STATEMENT_TIMEOUT_MS=30000

# CORS Security - Comma-separated list of allowed origins
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Rate Limiting
# Maximum requests per IP address within the time window
# Can be reconfigured at runtime via /api/admin/rate-limit endpoint
# Range: 1-10000
RATE_LIMIT_MAX_REQUESTS=100

# Time window for rate limiting in milliseconds
# Can be reconfigured at runtime via /api/admin/rate-limit endpoint
# Range: 1000-3600000 (1 second to 1 hour)
RATE_LIMIT_WINDOW_MS=60000

# Logging Level
LOG_LEVEL=INFO

# Metrics Access Control
METRICS_AUTH_TOKEN=
HEALTH_CHECK_ALWAYS_ENABLED=true
