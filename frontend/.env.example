# TipStream Frontend Environment Variables
# Copy this file to .env.local and adjust as needed.
# Vite exposes variables prefixed with VITE_ to the client bundle.

# Network: mainnet, testnet, or devnet (required)
# This determines which Stacks network to connect to
VITE_NETWORK=mainnet

# Hiro API URL (optional, defaults to https://api.hiro.so)
# VITE_HIRO_API_URL=https://api.hiro.so

# Application base URL used for canonical links, Open Graph, and share URLs (required)
# Set this to your deployment URL
VITE_APP_URL=https://tipstream-silk.vercel.app

# Telemetry configuration (optional)
# Enable remote telemetry ingestion for production monitoring
# VITE_TELEMETRY_ENABLED=true
# VITE_TELEMETRY_ENDPOINT=https://telemetry.example.com/ingest
# VITE_TELEMETRY_API_KEY=your-api-key
